<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:esriUI="clr-namespace:Esri.ArcGISRuntime.Maui;assembly=Esri.ArcGISRuntime.Maui"
             xmlns:esriTK="clr-namespace:Esri.ArcGISRuntime.Toolkit.Maui;assembly=Esri.ArcGISRuntime.Toolkit.Maui"
             x:Class="Toolkit.SampleApp.Maui.Samples.ScaleLineSample" Title="ScaleLine">
    <ContentPage.Content>
        <Grid>
            <esriUI:MapView x:Name="MainMapView" AutomationId="MainMapView"/>

            <Border Background="White" VerticalOptions="End" HorizontalOptions="Start">
                <Grid RowDefinitions="Auto,Auto">
                    <esriTK:ScaleLine Grid.Row="0"
                                      MapScale="{Binding MapScale, Source={x:Reference MainMapView}}"
                                      AutomationId="SimpleScaleLine"/>
                    <esriTK:ScaleLine Grid.Row="1"
                                      MapView="{x:Reference MainMapView}"
                                      AutomationId="AdvancedScaleLine"/>
                </Grid>
            </Border>
        </Grid>
    </ContentPage.Content>
</ContentPage>