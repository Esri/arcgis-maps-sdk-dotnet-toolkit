<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Toolkit.SampleApp.Maui.JobView">
    <Grid Height="60">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ProgressBar x:Name="ProgressBar" HorizontalOptions="Fill" Grid.ColumnSpan="2" VerticalOptions="Center" Height="60" Opacity=".5" />
        <VerticalStackLayout Margin="5">
            <Label x:Name="Status" FontAttributes="Bold" />
            <Label x:Name="Message" HorizontalOptions="Fill" />
        </VerticalStackLayout>
        <Button x:Name="PauseButton" Text="Pause" IsVisible="False" Clicked="PauseJob_Click" Grid.Column="1" VerticalOptions="Center" Margin="5" />
        <Button x:Name="ResumeButton" Text="Resume" IsVisible="False" Clicked="ResumeJob_Click" Grid.Column="1" VerticalOptions="Center" Margin="5" />
        <Button x:Name="DeleteButton" Text="Delete" IsVisible="False" Clicked="DeleteJob_Click" Grid.Column="1" VerticalOptions="Center" Margin="5" />
    </Grid>
</ContentView>
