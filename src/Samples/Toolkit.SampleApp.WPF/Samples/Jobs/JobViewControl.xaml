<UserControl x:Class="Esri.ArcGISRuntime.Toolkit.Samples.Jobs.JobViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Esri.ArcGISRuntime.Toolkit.Samples.Jobs"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <StackPanel>
            <TextBlock x:Name="Status" FontWeight="Bold" />
            <TextBlock x:Name="Message" TextWrapping="Wrap" HorizontalAlignment="Stretch" TextTrimming="CharacterEllipsis"/>
            <ProgressBar x:Name="ProgressBar" HorizontalAlignment="Stretch" Maximum="100" />
        </StackPanel>
</UserControl>
