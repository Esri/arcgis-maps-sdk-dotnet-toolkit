<UserControl x:Class="Esri.ArcGISRuntime.Toolkit.Samples.Jobs.JobViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Esri.ArcGISRuntime.Toolkit.Samples.Jobs"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Height="60">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ProgressBar x:Name="ProgressBar" HorizontalAlignment="Stretch" Maximum="100" Grid.ColumnSpan="2" VerticalAlignment="Center" Height="60" Opacity=".5" />
        <StackPanel Margin="5">
            <TextBlock x:Name="Status" FontWeight="Bold" />
            <TextBlock x:Name="Message" TextWrapping="Wrap" HorizontalAlignment="Stretch" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
        <Button x:Name="PauseButton" Content="Pause" Visibility="Collapsed" Click="PauseJob_Click" Grid.Column="1" VerticalAlignment="Center" Margin="5" />
        <Button x:Name="ResumeButton" Content="Resume" Visibility="Collapsed" Click="ResumeJob_Click" Grid.Column="1" VerticalAlignment="Center" Margin="5" />
        <Button x:Name="DeleteButton" Content="Delete" Visibility="Collapsed" Click="DeleteJob_Click" Grid.Column="1" VerticalAlignment="Center" Margin="5" />
    </Grid>
</UserControl>
