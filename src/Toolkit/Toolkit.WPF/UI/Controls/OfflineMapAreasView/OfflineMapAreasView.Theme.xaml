<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Esri.ArcGISRuntime.Toolkit.UI.Controls"
                    xmlns:primitives="clr-namespace:Esri.ArcGISRuntime.Toolkit.Primitives">
    <Style TargetType="{x:Type controls:OfflineMapAreasView}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:OfflineMapAreasView}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}"
                            MinWidth="{TemplateBinding MinWidth}"
                            MaxWidth="{TemplateBinding MaxWidth}">
                        <Grid>

                            <ListView x:Name="OfflineMapAreasListView" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="85">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding PortalItem.Title}" FontWeight="Bold" Grid.Column="1" Margin="4,0,0,0" FontSize="14" />
                                            <TextBlock Text="{Binding PortalItem.Description}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" ToolTip="{Binding PortalItem.Description}" Grid.Column="1" Margin="4,0,0,0" Grid.Row="1" />
                                            <primitives:RuntimeImageView RuntimeImage="{Binding PortalItem.Thumbnail}" Stretch="UniformToFill" Grid.RowSpan="2" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
