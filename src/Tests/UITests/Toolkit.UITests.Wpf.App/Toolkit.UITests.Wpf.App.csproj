<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <LangVersion>latest</LangVersion>
    <DefineConstants>$(DefineConstants);WPF_APP</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Lib.Harmony" Version="2.4.2" />
  </ItemGroup>

  <Choose>
    <When Condition=" '$(UseNugetPackage)' == '' ">
      <ItemGroup>
        <ProjectReference Include="..\..\..\Toolkit\Toolkit.WPF\Esri.ArcGISRuntime.Toolkit.WPF.csproj" />
        <PackageReference Include="Esri.ArcGISRuntime.WPF" Version="$(ArcGISRuntimePackageVersion)" />
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup>
        <PackageReference Include="Esri.ArcGISRuntime.Toolkit.WPF" Version="$(UseNugetPackage)" />
        <PackageReference Include="Esri.ArcGISRuntime.WPF" Version="$(UseNugetPackage)" />
      </ItemGroup>
    </Otherwise>
  </Choose>

  <Import Project="..\Toolkit.UITests.TestPages.Shared\Toolkit.UITests.TestPages.Shared.projitems" Label="Shared" />

</Project>
