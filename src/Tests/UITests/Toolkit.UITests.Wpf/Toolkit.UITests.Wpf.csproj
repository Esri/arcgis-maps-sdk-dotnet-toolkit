<Project Sdk="MSTest.Sdk" InitialTargets="CheckOS">

  <PropertyGroup>
    <TargetFramework>$(TestRunnerNetVersion)</TargetFramework>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <DefineConstants>$(DefineConstants);WINDOWS_RUNNER;WINDOWS_TEST;WPF_TEST</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Appium.WebDriver" Version="$(AppiumWebDriverVersion)" />
    <PackageReference Include="Magick.NET-Q8-AnyCPU" Version="$(MagickNetVersion)" />
  </ItemGroup>

  <Import Project="..\Toolkit.UITests.Shared\Toolkit.UITests.Shared.projitems" Label="Shared" />

  <!-- The WPF tests should only run on a Windows machine -->
  <Target Name="CheckOS">
    <Warning Condition="$([MSBuild]::IsOSPlatform('Windows')) != 'true'" Text="The WPF tests must be run from a Windows machine" />
  </Target>

  <!-- Build test app if needed and record build location to SampleAppBuildInfo.txt -->
  <Target Name="BuildTestApp" BeforeTargets="Build">
    <MSBuild Projects="..\..\UITests\Toolkit.UITests.Wpf.App\Toolkit.UITests.Wpf.App.csproj" Targets="Build" Properties="Configuration=$(Configuration)">
      <Output TaskParameter="TargetOutputs" ItemName="_TestAppTargetOutputs" />
    </MSBuild>

    <PropertyGroup>
      <_TestAppExePath>@(_TestAppTargetOutputs->'%(FullPath)')</_TestAppExePath>
      <_TestAppExePath>$(_TestAppExePath.Replace(dll,exe))</_TestAppExePath>
    </PropertyGroup>

    <Message Importance="high" Text="WPF Sample app built at: $(_TestAppExePath)" />
    <WriteLinesToFile File="$(TargetDir)AppBuildInfo.txt" Lines="app=$(_TestAppExePath)" Overwrite="true" Encoding="UTF-8" />
  </Target>

</Project>
