<Project Sdk="MSTest.Sdk">

  <PropertyGroup>
    <TargetFramework>$(TestRunnerNetVersion)</TargetFramework>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <DefineConstants>$(DefineConstants);WINDOWS_RUNNER;WINDOWS_TEST;WINUI_TEST</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Appium.WebDriver" Version="$(AppiumWebDriverVersion)" />
    <PackageReference Include="Magick.NET-Q8-AnyCPU" Version="$(MagickNetVersion)" />
  </ItemGroup>

  <Import Project="..\Toolkit.UITests.Shared\Toolkit.UITests.Shared.projitems" Label="Shared" />

  <!-- The WinUI tests should only run on a Windows machine -->
  <Target Name="CheckOS">
    <Warning Condition="$([MSBuild]::IsOSPlatform('Windows')) != 'true'" Text="The WinUI tests must be run from a Windows machine" />
  </Target>

</Project>
